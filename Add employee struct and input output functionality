#include <stdio.h>

struct date {
    int day, month, year;
};

struct employee {
    char name[50];
    int id;
    float salary;
    struct date dob;
};

int main() {
    struct employee e;

    printf("Enter name: ");
    scanf("%s", e.name);

    printf("Enter id: ");
    scanf("%d", &e.id);

    printf("Enter salary: ");
    scanf("%f", &e.salary);

    printf("Enter DOB (dd mm yyyy): ");
    scanf("%d %d %d", &e.dob.day, &e.dob.month, &e.dob.year);

    printf("\nName: %s\nID: %d\nSalary: %.2f\nDOB: %d/%d/%d\n",
           e.name, e.id, e.salary,
           e.dob.day, e.dob.month, e.dob.year);

    return 0;
}
