#include <stdio.h>

int recursiveSum(int arr[], int n) {
    if(n == 0)
        return 0;
    return arr[n-1] + recursiveSum(arr, n-1);
}

int main() {
    int arr[100], n, i, sum = 0;

    printf("Enter size: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    for(i = 0; i < n; i++)
        sum += arr[i];

    printf("Sum using iteration = %d\n", sum);
    printf("Sum using recursion = %d\n", recursiveSum(arr, n));

    return 0;
}
